    "@vkontakte/vk-bridge": "^2.15.11",
    "@vkontakte/vk-bridge-react": "^1.1.2",
    "@vkontakte/vk-mini-apps-router": "^1.8.4",
    "@vkontakte/vkui": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
