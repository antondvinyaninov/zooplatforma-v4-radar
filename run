#!/bin/bash

# Ловим Ctrl+C и убиваем все запущенные команды этого скрипта разом
trap 'kill 0' SIGINT

# Очищаем порты от зависших (зомби) процессов с прошлых запусков
lsof -ti:3000,5173 | xargs kill -9 >/dev/null 2>&1 || true

echo "🚀 Запуск Бэкенда (порт 3000)..."
cd backend && npm run dev &

echo "🚀 Запуск Фронтенда (порт 5173)..."
# Переходим в папку фронтенда (так как основной скрипт остался в корне проекта)
cd vk_post_app && npm run start &

# Ожидаем завершения фоновых процессов (чтобы скрипт не закрылся сразу)
wait
