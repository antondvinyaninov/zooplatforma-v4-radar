#!/bin/bash

# Ловим Ctrl+C и убиваем все запущенные команды этого скрипта разом
trap 'kill 0' SIGINT

# Очищаем порты от зависших (зомби) процессов с прошлых запусков
lsof -ti:3000,5173,5174 | xargs kill -9 >/dev/null 2>&1 || true

MY_IP="192.168.0.13"

echo "----------------------------------------------------"
echo "🚀 ZooPlatform Ecosystem Starting..."
echo "📍 Твой сетевой IP: $MY_IP"
echo "🌐 Радар: https://$MY_IP:5173"
echo "----------------------------------------------------"

echo "🚀 Запуск Бэкенда (порт 3000)..."
cd backend && npm run dev &

echo "🚀 Запуск Супер-приложения Радар (https://$MY_IP:5173)..."
cd vk_radar_app && npm run start -- --host &

# Ожидаем завершения фоновых процессов
wait
